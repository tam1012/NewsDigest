# ========== Cloudflare project names ==========
# ⚠️ You MUST change these to your own unique names!
# PAGES_PROJECT_NAME must be globally unique (it becomes <name>.pages.dev).
WORKER_NAME=newsdigest
PAGES_PROJECT_NAME=newsdigest-fe

# ========== Cloudflare resources ==========
D1_DATABASE_NAME=newsdigest
KV_SCRAPER_CONFIG_NAME=newsdigest-scraper-config
QUEUE_NAME=article-content-queue
QUEUE_DLQ_NAME=article-content-dlq

# Optional: set this if you use a custom domain for Worker.
# If empty, deploy script will try to auto-detect workers.dev URL after deploy.
WORKER_PUBLIC_URL=

# ========== Required runtime secrets ==========

# Cloudflare AI Gateway URL.
# Format: https://gateway.ai.cloudflare.com/v1/<your_account_id>/<your_gateway_name>/google-ai-studio
# Create a gateway at: https://dash.cloudflare.com → AI → AI Gateway
AI_GATEWAY_URL=

# AI Gateway authorization token.
AI_GATEWAY_TOKEN=

# RapidAPI key — used to fetch YouTube subtitles/transcripts via yt-api.
# Subscribe at: https://rapidapi.com/ytjar/api/yt-api
RAPIDAPI_KEY=

# ========== Optional runtime secrets ==========

# YouTube Data API v3 key — optional but recommended as fallback.
# The scraper will try free RSS feeds first, but if YouTube RSS is down,
# it falls back to the API. Get it at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Admin API key — protects write endpoints (add/delete sources, resummarize, etc.)
# Leave empty to disable admin auth (not recommended for production).
ADMIN_API_KEY=

# ========== AI Prompt Configuration (all optional) ==========
# These variables let you customize the AI prompts without touching source code.
# All fields are optional — defaults produce the original Vietnamese tech-news behavior.

# Language for all AI output (summaries, digest).
# Use the full language name, e.g. "Vietnamese", "English", "Japanese", "French".
# Default: Vietnamese
PROMPT_OUTPUT_LANGUAGE=

# Comma-separated list of topic areas that receive higher hot_scores.
# Default: AI/LLM, Security, Dev Tools, Startup/Business
PROMPT_TOPIC_PRIORITIES=

# Comma-separated whitelist of tags the AI can assign to articles.
# Default: AI, Tech, Security, Business, Vietnam, World, Dev, Science, Crypto, Policy, Entertainment
PROMPT_ALLOWED_TAGS=

# Comma-separated suggested heading groups for the daily digest.
# Note: these are HINTS for the AI, not strict categories — the model may use
# fewer or different headings depending on the actual content of the day.
# Default: AI & LLM, Security, Tools & Infrastructure, Startup & Business, Policy & Society
PROMPT_DIGEST_HEADINGS=

# Optional extra context appended to system prompts (plain text only).
# Use this to add audience/domain context, e.g. "Focus on Southeast Asian tech market."
# WARNING: plain text only — do NOT use XML tags or special markup, they will be stripped.
# Default: (empty)
PROMPT_CUSTOM_CONTEXT=
